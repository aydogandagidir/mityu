{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/fonts/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "mityu.vercel.app" }],
      "destination": "https://mityu.bluedev.dev/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "mityu-adagidir.vercel.app" }],
      "destination": "https://mityu.bluedev.dev/$1",
      "permanent": true
    }
  ]
}
